
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow read access to all users for profile pictures
    match /profile-pictures/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Allow read/write access to wound images only for the authenticated user
    match /wound-images/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Allow read/write access to wound captures only for the authenticated user
    match /wound-captures/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
