
{
  "rules": {
    "conversations": {
      "$conversationId": {
        ".read": "auth != null && (data.child('participants').child(auth.uid).val() === true || data.child('professionalId').val() === auth.uid)",
        ".write": "auth != null && (data.child('participants').child(auth.uid).val() === true || data.child('professionalId').val() === auth.uid)",
        "messages": {
          "$messageId": {
            ".read": "auth != null && (root.child('conversations').child($conversationId).child('participants').child(auth.uid).val() === true || root.child('conversations').child($conversationId).child('professionalId').val() === auth.uid)",
            ".write": "auth != null && (root.child('conversations').child($conversationId).child('participants').child(auth.uid).val() === true || root.child('conversations').child($conversationId).child('professionalId').val() === auth.uid)"
          }
        }
      }
    }
  }
}
